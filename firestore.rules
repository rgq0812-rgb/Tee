rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check - bootstrap user: rgq0812@gmail.com
    function isAdmin() { 
      return isSignedIn() && (request.auth.token.email == "rgq0812@gmail.com" && request.auth.token.email_verified == true);
    }

    // --- Entities Validators ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'handicap', 'createdAt', 'email', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.handicap is number && data.handicap >= -10 && data.handicap <= 54 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             data.email == request.auth.token.email;
    }

    function isValidRound(data) {
      return data.keys().hasAll(['userId', 'courseId', 'courseName', 'date', 'status', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             isValidId(data.courseId) &&
             data.courseName is string && data.courseName.size() <= 200 &&
             data.date is string && 
             data.status in ['in-progress', 'completed'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidHole(data) {
      return data.keys().hasAll(['holeNumber', 'par', 'score']) &&
             data.holeNumber >= 1 && data.holeNumber <= 18 &&
             data.par >= 3 && data.par <= 6 &&
             data.score >= 1 && data.score <= 15;
    }

    function isValidHoleAsset(data) {
      return data.keys().hasAll(['userId', 'courseId', 'holeNumber', 'imageData', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.imageData is string && data.imageData.size() <= 900000;
    }

    function isValidTacticalAdvice(data) {
       return data.keys().hasAll(['userId', 'caddieName', 'holeNumber', 'courseName', 'advice', 'createdAt']) &&
              data.userId == request.auth.uid &&
              data.createdAt == request.time &&
              data.advice is string && data.advice.size() <= 3000;
    }

    // --- Path Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'handicap', 'updatedAt']) &&
        incoming().updatedAt == request.time
      );
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /hole_assets/{assetId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified() && isValidHoleAsset(incoming());
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /tactical_advice/{adviceId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isVerified() && isValidTacticalAdvice(incoming());
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /rounds/{roundId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidRound(incoming());
      allow update: if isOwner(existing().userId) && (
        incoming().updatedAt == request.time &&
        (existing().status == 'in-progress' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore', 'totalPutts', 'gir', 'fairwaysHit', 'updatedAt']))
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /rounds/{roundId}/holes/{holeId} {
      function canAccessRound() {
        return get(/databases/$(database)/documents/rounds/$(roundId)).data.userId == request.auth.uid;
      }
      allow read: if canAccessRound();
      allow create, update, delete: if canAccessRound();
    }

    match /swingAnalyses/{analysisId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isVerified() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
